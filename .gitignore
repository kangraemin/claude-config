# 추적할 것만 화이트리스트 방식으로 관리
*

# 추적 대상
!.gitignore
!README.md
!install.sh
!CLAUDE.md
!settings.json

# agents
!agents/
!agents/**

# commands
!commands/
!commands/**

# guides
!guides/
!guides/**

# skills
!skills/
!skills/**

# rules
!rules/
!rules/**

# hooks
!hooks/
!hooks/**

# git-hooks (global git hooks)
!git-hooks/
!git-hooks/**

# scripts
!scripts/
!scripts/**

# tests
!tests/
!tests/**

# memory (auto memory)
!projects/
!projects/-Users-ram/
!projects/-Users-ram/memory/
!projects/-Users-ram/memory/**

# worklogs (git 추적 안 함)
.worklogs/

# 임시 상태 파일 (hook runtime)
hooks/.library-check-counter*
hooks/.learnings-version
hooks/.learnings-version-checked

# workspace 디렉토리 (스킬 개발용 임시)
skills/*-workspace/

# 백업/임시 파일
scripts/*.bak
agents/*.pre-update

# ai-worklog 프로젝트 소속 파일 (install.sh로 설치됨, 여기서 추적 안 함)
install.sh
commands/finish.md
commands/migrate-worklogs.md
commands/update-worklog.md
commands/worklog.md
hooks/post-commit.sh
hooks/session-end.sh
hooks/stop.sh
hooks/worklog.sh
rules/auto-commit-rules.md
rules/worklog-rules.md
scripts/duration.py
scripts/notion-create-db.sh
scripts/notion-migrate-worklogs.sh
scripts/notion-worklog.sh
scripts/token-cost.py
scripts/update-check.sh
scripts/worklog-write.sh
git-hooks/post-commit
.claude-library/
